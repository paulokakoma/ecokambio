# Ficheiros de configuração do Git
.git
.gitignore

# Dependências locais que não devem ser copiadas para a imagem
node_modules

# Ficheiros de ambiente (devem ser geridos fora da imagem)
.env
.env.fly

# Logs e ficheiros de depuração
npm-debug.log
logs/

# Dados de sessão locais (não devem entrar na imagem)
sessions/

# Armazenamento local e certificados
storage/
scratch/
certs/

# Ficheiros Extra GIGANTES que travam o deploy
ecopay
.venv
.cursor
.claude
.agent
.agents

# Ficheiros de desenvolvimento
.DS_Store
.gitkeep