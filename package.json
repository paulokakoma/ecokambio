{
  "name": "currency-main",
  "version": "1.0.0",
  "description": "A currency exchange application with user credits and admin notifications.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js --host 0.0.0.0",
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "scrape": "node webscraper/cron-scraping.js",
    "scrape:informal": "node webscraper/angocambio-scraper.js",
    "scrape:usdt": "node webscraper/usdt-formal-scraper.js && node webscraper/usdt-informal-scraper.js",
    "scrape:all": "node webscraper/run-all-scrapers.js",
    "scrape:puppeteer": "node webscraper/puppeteer-scraper.js",
    "worker": "node worker.js",
    "build:prod": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "dev": "concurrently \"tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch\" \"nodemon server.js\"",
    "fly:build": "npx playwright install --with-deps chromium && npm run build:prod",
    "ai:train": "echo 'Script desativado - diretório src/ai/ não existe'"
  },
  "keywords": [
    "express",
    "supabase",
    "resend",
    "tailwindcss"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.932.0",
    "@sentry/node": "^7.100.0",
    "@supabase/supabase-js": "^2.43.5",
    "@xenova/transformers": "^2.17.2",
    "acorn": "^8.17.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.4.1",
    "cheerio": "^1.0.0",
    "compression": "^1.8.1",
    "connect-redis": "^7.1.1",
    "cookie-parser": "^1.4.7",
    "crawlee": "^3.15.3",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "openai": "^6.48.0",
    "playwright": "^1.56.1",
    "session-file-store": "^1.5.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "twilio": "^5.11.1",
    "winston": "^3.18.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "tailwindcss": "^3.4.4"
  }
}
